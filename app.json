{
  "expo": {
    "name": "Império do Café",
    "slug": "rpg-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rickjs.imperiodocafe"
    },
    "android": {
      "package": "com.rickjs.imperiodocafe",
      "adaptiveIcon": {
        "backgroundColor": "#f3ecd0",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#f3ecd0"
        }
      ]
    ]
  }
}
